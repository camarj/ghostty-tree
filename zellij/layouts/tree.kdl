layout {
    tab name="tree" hide_floating_panes=true {
        pane name="shell"
        floating_panes {
            pane name="yazi" x="65%" y="0%" width="35%" height="100%" {
                command "sh"
                args "-c" "ID=\"$(date +%s)$$\"; mkdir -p /tmp; printf %s \"$ID\" > \"/tmp/yazi-zellij-${ZELLIJ_SESSION_NAME:-default}.id\"; exec yazi --client-id \"$ID\""
            }
        }
    }
}
